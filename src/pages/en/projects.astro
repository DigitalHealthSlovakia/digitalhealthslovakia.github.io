---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = "Projects | Digital Health Slovakia";
const description = "Discover the international and national initiatives led by Digital Health Slovakia.";
---

<BaseLayout title={title} description={description}>
  
  <div class="content-wrapper" style="padding-top: 2rem;">
    
    <header data-animate>
      <h1>CURRENT PROJECTS</h1>
      <p class="mission-p">
        Digital Health Slovakia is actively involved in several international and national initiatives.
      </p>
    </header>

    <section style="margin-top: 4rem;" data-animate>
      <div style="margin-bottom: 2rem;">
        <h2>XiA Project</h2>
        <p class="mission-p">
          The Xpanding Innovative Alliance (XiA) is a European initiative focused on the practical implementation of the European Health Data Space (EHDS). The project addresses the technical and professional challenges of interoperability by developing a specialized pedagogical framework and micro-credentials. By centering our efforts on the European Electronic Health Record Exchange Format (EEHRxF), XiA provides the training infrastructure and accreditation necessary for IT professionals and healthcare providers to operate within a unified, cross-border digital health ecosystem.
        </p>
      </div>

      <div style="display: flex; justify-content: center;">
        <a href="https://xia-project.iscte-iul.pt/" target="_blank" rel="noopener noreferrer" class="project-image-link">
          <img 
            src="/images/XiA-Launch_Surveys-1024x577.png" 
            alt="XIA Project Website" 
            class="project-banner cinematic-lift"
          />
        </a>
      </div>
    </section>

    <div style="margin-bottom: 8rem;"></div>

  </div>
</BaseLayout>

<style>
  .project-banner {
    /* SIZING RESTORED */
    width: 100%;
    max-width: 900px; 
    height: auto;
    border-radius: 15px;
    
    /* GLOBAL STYLE OVERRIDE */
    display: block;
    margin: 0 auto;
    
    /* THE CINEMATIC BASE */
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    transition: 
      transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), 
      box-shadow 0.5s ease;
  }

  .project-image-link {
    display: block;
    cursor: pointer;
    text-decoration: none;
  }

  /* THE HOVER */
  .project-image-link:hover .project-banner {
    /* Scale + Lift */
    transform: scale(1.03) translateY(-10px);
    
    /* Deep Purple Glow shadow using your brand variable */
    box-shadow: 0 30px 60px rgba(75, 0, 130, 0.25);
  }

  /* Ensuring the text doesn't look weird when the image is centered */
  @media (max-width: 768px) {
    header, h2 {
      text-align: center;
    }
  }
</style>