---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 3em 20px;
			}
			
			/* HERO SECTION */
			.hero {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 60px;
				margin-bottom: 5rem;
			}
			.hero-text {
				flex: 1;
			}
			.hero-text h1 {
				color: #4b0082;
				font-size: 3.8rem;
				line-height: 1.1;
				margin-bottom: 0.5rem;
			}
			.hero-text p.mission-statement {
				font-size: 1.5rem;
				line-height: 1.4;
				color: #1a1a3a;
				margin-bottom: 1.5rem;
			}
			.hl7-logo-container {
				flex-shrink: 0;
			}
			.hl7-logo-container img {
				width: 240px;
				height: auto;
			}

			/* BANNER */
			.main-banner {
 				 max-width: 900px;
 				 margin: 0 auto 5rem;
			}

			.main-banner img {
  				transform: scale(0.95);
			}

			/* KEY ACTIVITIES - FULL WIDTH BREAKOUT */
			.activities-strip {
				background-color: #4b0082;
				color: #ffffff;
				padding: 80px 0;
				margin: 5rem 0;
				width: 100vw;
				position: relative;
				left: 50%;
				right: 50%;
				margin-left: -50vw;
				margin-right: -50vw;
			}
			.activities-inner {
				max-width: 900px;
				margin: 0 auto;
				padding: 0 20px;
			}
			.activities-inner h2 {
				text-align: center;
				font-size: 2.5rem;
				margin-bottom: 2.5rem;
				color: #ffffff;
			}
			.activities-list {
				list-style: none;
				padding: 0;
			}
			.activities-list li {
				font-size: 1.3rem;
				margin-bottom: 1.2rem;
				display: flex;
				align-items: flex-start;
				gap: 20px;
			}
			.activities-list li::before {
				content: "✓";
				color: #8134af;
				font-weight: bold;
				font-size: 1.5rem;
				line-height: 1;
			}

			/* TEAM SECTION */
			.team-section {
				margin-bottom: 6rem;
			}
			.team-section h2 {
				text-align: center;
				color: #4b0082;
				font-size: 3rem;
				margin-bottom: 3rem;
			}
			.team-grid {
				display: grid;
				grid-template-columns: repeat(5, 1fr);
				gap: 25px;
			}
			.team-card {
				text-align: center;
			}
			.team-card img {
				width: 160px;
				height: 160px;
				border-radius: 50%;
				border: 5px solid #8134af;
				object-fit: cover;
				margin-bottom: 1rem;
				transition: transform 0.3s ease;
			}
			.team-card img:hover {
				transform: scale(1.05);
			}
			.team-card h3 {
				font-size: 1.1rem;
				margin: 5px 0;
				color: #1a1a3a;
			}
			.team-card p {
				font-size: 0.9rem;
				color: #666;
				font-weight: 700;
				text-transform: uppercase;
			}

			/* PARTNERS SECTION */
			.partners-section {
				margin-bottom: 6rem;
			}

			.partners-section h2 {
				text-align: center;
				color: #4b0082;
				font-size: 3rem;
				margin-bottom: 3rem;
			}

			/* LOGO GRID SYSTEM */
			.divider-bar {
				background-color: #1a1a3a;
				color: #ffffff;
				padding: 18px 0;
				text-align: center;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 2px;
				margin: 4rem 0 2.5rem;

			/* FULL-WIDTH BREAKOUT */
				width: 100vw;
				position: relative;
				left: 50%;
				right: 50%;
				margin-left: -50vw;
				margin-right: -50vw;
			}

			.divider-inner {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 20px;
			}

			.logo-grid {
				display: grid;
				grid-template-columns: repeat(5, 1fr);
				gap: 30px;
				align-items: start;
			}
			.logo-grid-3 {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 40px;
				max-width: 900px;
				margin: 0 auto;
			}
			.logo-grid--supported {
			  	display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 30px;
			}
			.logo-grid--supported > a {
				flex: 0 1 calc(20% - 30px);
				min-width: 160px;
				display: flex;
  				justify-content: center;
			}
			.logo-item {
				text-align: center;
			}
			.logo-container {
				height: 100px;
				display: flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 15px;
			}
			.logo-container img {
				max-height: 80px;
				max-width: 100%;
				object-fit: contain;
			}
			.logo-label {
				display: block;
				font-size: 0.75rem;
				font-weight: 900;
				color: #4b0082;
				text-transform: uppercase;
				line-height: 1.3;
			}


		/* Scroll animation baseline */
		[data-animate] {
		opacity: 0;
		transform: translateY(30px);
		}

		.fade-up {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 0.7s ease-out,
			transform 0.7s ease-out;
		}

		<script>
		const observer = new IntersectionObserver(
			entries => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
				entry.target.classList.add('fade-up');
				observer.unobserve(entry.target);
				}
			});
			},
			{ threshold: 0.15 }
		);

		document.querySelectorAll('[data-animate]').forEach(el => {
			observer.observe(el);
		});
		</script>


		@media (max-width: 1024px) {
		.team-grid {
			grid-template-columns: repeat(3, 1fr);
		}

		.logo-grid {
			grid-template-columns: repeat(3, 1fr);
		}
		}

		@media (max-width: 640px) {
		.hero {
			flex-direction: column;
			text-align: center;
			gap: 30px;
		}

		.hero-text h1 {
			font-size: 2.6rem;
		}

		.team-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.logo-grid,
		.logo-grid-3 {
			grid-template-columns: repeat(2, 1fr);
		}

		.logo-grid--supported > a {
			flex: 0 1 calc(50% - 30px);
		}
		}		

	</style>

