---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Data Imports
import { team } from '../../data/team';
import { members } from '../../data/members';
import { affiliations } from '../../data/affiliations';
import { supporters } from '../../data/supporters';

const title = "About Us";
const description = "Learn about Digital Health Slovakia, our mission, our team, and our partners.";
---

<BaseLayout title={title} description={description}>

  <div class="content-wrapper" style="padding-top: 2rem;">
    <section class="hero-flex" data-animate>
      <div class="hero-mission-text">
        <h1>OUR MISSION</h1>
        <p style="font-size: 1.5rem; color: var(--navy-dark); margin-bottom: 1.5rem; line-height: 1.4;">
          Digital Health Slovakia is a non-profit association focused on promoting and advancing interoperability and standardization of healthcare in Slovakia.
        </p>
     	 	<p class="mission-p">
			    <strong>HL7 Slovakia</strong> — the Slovak affiliate of HL7 International — is part of Digital Health Slovakia.
 			</p>
      </div>
      <div class="hl7-logo-box">
        <img src="/images/HL7_SK_logo.png" alt="HL7 Slovakia Logo" class="hl7-logo-img" />
      </div>
    </section>

    <div style="margin-bottom: 3rem;" data-animate>
      <img src="/images/About_01_EN.png" alt="Digital Health Strategic Vision" class="strategic-banner" />
    </div>
  </div>

  <section class="purple-activities-strip" data-animate>
    <div class="content-wrapper">
      <h2 style="color: white; margin-bottom: 2rem;">OUR KEY ACTIVITIES</h2>
      <ul class="activities-list">
        <li>support of digital health interoperability and standardisation</li>
        <li>support of sustainable, patient centric healthcare</li>
        <li>creating a community of digital health standards users, experts and P3 stakeholders</li>
        <li>promotion of digital health training, research, and innovation</li>
        <li>cooperation with national and international digital health institutions</li>
      </ul>
    </div>
  </section>

  <div class="content-wrapper">
    <section style="padding: 3rem 0;" data-animate>
      <h2>OUR TEAM</h2>
      <div class="team-grid">
        {team.map((person) => (
          <div class="team-card">
            <img src={person.img} alt={person.name} />
            <h3>{person.name}</h3>
            <p>{person.titleEn}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <div class="navy-divider">Members of Digital Health Slovakia</div>
  <div class="content-wrapper">
    <div class="logo-flex-row" data-animate>
      {members.map((member) => (
        <a href={member.urlEn} target="_blank" rel="noopener noreferrer" class="logo-item">
          <div class="logo-img-wrapper">
            <img src={member.logoEn} alt={member.nameEn} />
          </div>
          <span class="logo-text-label">{member.nameEn}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="navy-divider">Digital Health Slovakia is a Member of</div>
  <div class="content-wrapper">
    <div class="logo-flex-row" data-animate>
      {affiliations.map((org) => (
        <a href={org.url} target="_blank" rel="noopener noreferrer" class="logo-item">
          <div class="logo-img-wrapper">
            <img src={org.logo} alt={org.name} />
          </div>
          <span class="logo-text-label">{org.name}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="navy-divider">Digital Health Slovakia is Supported By</div>
  <div class="content-wrapper">
    <div class="logo-flex-row" data-animate>
      {supporters.map((supporter) => (
        <a href={supporter.url} target="_blank" rel="noopener noreferrer" class="logo-item">
          <div class="logo-img-wrapper">
            <img src={supporter.logo} alt={supporter.nameEn} />
          </div>
          <span class="logo-text-label">{supporter.nameEn}</span>
        </a>
      ))}
    </div>
  </div>

</BaseLayout>