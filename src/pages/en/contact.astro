---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = "Contact | Digital Health Slovakia";
---

<BaseLayout title={title}>
  <div class="content-wrapper" style="padding-top: 2rem;">
    
    <header data-animate>
      <h1>CONTACT US</h1>
      <p class="mission-p">
        Get in touch with us regarding our initiatives, HL7 implementation, or membership opportunities.
      </p>
    </header>

    <section class="contact-section" data-animate>
      <form action="PASTE_YOUR_AZURE_URL_HERE" method="POST" class="contact-form">
        
        <div class="form-group">
          <label for="email">Your Email</label>
          <input type="email" id="email" name="email" placeholder="email@example.com" required />
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" placeholder="How can we help you?" required></textarea>
        </div>

        <div class="form-checkbox">
          <input type="checkbox" id="gdpr" name="gdpr" required />
          <label for="gdpr">
            I agree to the processing of my personal data and receiving communications in accordance with GDPR.
          </label>
        </div>

        <button type="submit" class="submit-btn">Send Message</button>
      </form>
    </section>

  </div>
</BaseLayout>

<style>
  .contact-section {
    margin-top: 4rem;
    max-width: 700px;
    margin-bottom: 6rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .form-group label {
    font-weight: 700;
    color: var(--purple-main);
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05rem;
  }

  .form-group input, 
  .form-group textarea {
    padding: 1rem;
    border: 2px solid #eee;
    border-radius: 8px;
    font-size: 1.1rem;
    font-family: inherit;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus, 
  .form-group textarea:focus {
    outline: none;
    border-color: var(--purple-main);
  }

  .form-checkbox {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    font-size: 0.95rem;
    line-height: 1.5;
    color: #666;
  }

  .form-checkbox input {
    margin-top: 0.3rem;
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .submit-btn {
    background-color: var(--purple-main);
    color: white;
    padding: 1rem 2.5rem;
    border: none;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
    align-self: flex-start;
  }

  .submit-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
</style>